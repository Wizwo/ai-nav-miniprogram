/* pages/category/category.wxss */
.category-tabs { display: flex; flex-wrap: wrap; padding: 20rpx; gap: 16rpx; background: #1a1a2e; }
.tab { display: flex; align-items: center; gap: 8rpx; padding: 14rpx 24rpx; border-radius: 50rpx; background: #16213e; border: 1px solid rgba(255,255,255,0.08); transition: all 0.2s; }
.tab.active { background: rgba(100,255,218,0.15); border-color: #64ffda; }
.tab-icon { font-size: 28rpx; }
.tab-name { font-size: 26rpx; color: #e6e6e6; }
.tab-count { font-size: 22rpx; color: #8892b0; background: rgba(255,255,255,0.08); padding: 2rpx 10rpx; border-radius: 20rpx; }
.tools-list { padding: 20rpx; }
.tool-item { display: flex; gap: 24rpx; padding: 24rpx; background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 16rpx; margin-bottom: 20rpx; border: 1px solid rgba(255,255,255,0.05); }
.tool-logo { width: 96rpx; height: 96rpx; border-radius: 20rpx; background: #0f0f1a; flex-shrink: 0; }
.tool-info { flex: 1; min-width: 0; }
.tool-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.tool-name { font-size: 30rpx; font-weight: 600; color: #e6e6e6; }
.tool-tags { display: flex; gap: 8rpx; }
.tool-desc { font-size: 24rpx; color: #8892b0; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.tool-meta { display: flex; justify-content: space-between; align-items: center; margin-top: 10rpx; }
.tool-cat { font-size: 22rpx; }
.tool-rating { display: flex; align-items: center; gap: 8rpx; font-size: 22rpx; color: #ffd700; }
.dot { color: #8892b0; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 100rpx 0; gap: 16rpx; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 28rpx; color: #8892b0; }
