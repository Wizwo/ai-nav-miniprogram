<view class="container">

  <!-- 骨架屏 -->
  <skeleton show="{{loading && !tools.length}}" type="list" />

  <!-- 出错 -->
  <view class="error-wrap" wx:if="{{error}}">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <view class="retry-btn" bindtap="fetchInit">重试</view>
  </view>

  <!-- 分类标签 -->
  <view class="category-tabs">
    <view class="tab {{activeCategory === item.id ? 'active' : ''}}"
          wx:for="{{categories}}" wx:key="id"
          bindtap="selectCategory" data-id="{{item.id}}" data-name="{{item.name}}">
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-name">{{item.name}}</text>
      <text class="tab-count">{{item.count}}</text>
    </view>
  </view>

  <!-- 工具列表 -->
  <view class="tools-list" wx:if="{{tools.length > 0}}">
    <view class="tool-item" wx:for="{{tools}}" wx:key="id"
          bindtap="goToDetail" data-id="{{item.id}}">
      <image class="tool-logo" src="{{item.logo}}" mode="aspectFit" binderror="onImgErr" />
      <view class="tool-info">
        <view class="tool-header">
          <text class="tool-name">{{item.name}}</text>
          <view class="tool-tags">
            <text class="tag tag-primary" wx:if="{{item.free}}">免费</text>
            <text class="tag tag-secondary" wx:if="{{item.chinese}}">中文</text>
          </view>
        </view>
        <text class="tool-desc">{{item.description}}</text>
        <view class="tool-meta">
          <text class="tool-cat" style="color:{{item.catColor}}">{{item.category}}</text>
          <view class="tool-rating">
            <text>⭐ {{item.rating}}</text>
            <text class="dot">·</text>
            <text>{{item.users}}人在用</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{!loading && activeCategory && tools.length === 0 && !error}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">该分类暂无工具</text>
  </view>

</view>
