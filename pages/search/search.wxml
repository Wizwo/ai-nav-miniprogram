<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索AI工具..." value="{{searchValue}}" bindinput="onInput" bindconfirm="onSearch" confirm-type="search" auto-focus placeholder-class="ph" />
    <text class="search-btn" bindtap="onSearch">搜索</text>
  </view>
  <view wx:if="{{showHistory}}">
    <view class="history-section" wx:if="{{recentSearch.length > 0}}">
      <view class="section-header"><text class="section-title">🕐 搜索历史</text><text class="clear-btn" bindtap="clearHistory">清空</text></view>
      <view class="history-list"><text class="history-item" wx:for="{{recentSearch}}" wx:key="index" bindtap="tapHistory" data-value="{{item}}">{{item}}</text></view>
    </view>
    <view class="hot-section"><text class="section-title">🔥 猜你想搜</text>
      <view class="hot-list"><text class="hot-item" wx:for="{{hotWords}}" wx:key="index" bindtap="tapHistory" data-value="{{item}}">{{item}}</text></view>
    </view>
    <view class="cat-section"><text class="section-title">📂 分类</text>
      <view class="cat-grid"><view class="cat-item" wx:for="{{categories}}" wx:key="id" bindtap="tapHistory" data-value="{{item.name}}"><text class="cat-icon">{{item.icon}}</text><text class="cat-name">{{item.name}}</text></view></view>
    </view>
  </view>
  <view class="result-list" wx:if="{{!showHistory}}">
    <view class="result-item" wx:for="{{result}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="result-logo" src="{{item.logo}}" mode="aspectFit" />
      <view class="result-info">
        <text class="result-name">{{item.name}}</text>
        <text class="result-desc">{{item.shortDesc}}</text>
        <view class="result-meta"><text class="result-cat" style="color:{{item.catColor}}">{{item.category}}</text><text class="result-rating">⭐ {{item.rating}}</text></view>
      </view>
    </view>
    <view class="no-result" wx:if="{{result.length === 0 && searchValue}}"><text class="no-result-icon">🔍</text><text class="no-result-text">未找到「{{searchValue}}」相关工具</text><text class="no-result-hint">试试其他关键词</text></view>
  </view>
</view>