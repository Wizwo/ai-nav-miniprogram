<view class="container">

  <!-- 搜索框 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索AI工具..."
      value="{{searchValue}}"
      bindinput="onInput"
      bindconfirm="onSearch"
      confirm-type="search"
      auto-focus
      placeholder-class="ph"
    />
    <text class="search-btn" bindtap="onSearch">搜索</text>
  </view>

  <!-- 搜索历史 -->
  <view class="section" wx:if="{{showHistory && recentSearch.length > 0}}">
    <view class="section-header">
      <text class="section-title">🕐 搜索历史</text>
      <text class="clear-btn" bindtap="onClearHistory">清空</text>
    </view>
    <view class="chip-list">
      <text class="chip" wx:for="{{recentSearch}}" wx:key="index"
            bindtap="onTapChip" data-value="{{item}}">{{item}}</text>
    </view>
  </view>

  <!-- 猜你想搜 -->
  <view class="section" wx:if="{{showHistory}}">
    <text class="section-title">🔥 猜你想搜</text>
    <view class="chip-list">
      <text class="chip chip-primary" wx:for="{{hotWords}}" wx:key="index"
            bindtap="onTapChip" data-value="{{item}}">{{item}}</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <text class="loading-text">搜索中...</text>
  </view>

  <!-- 搜索结果 -->
  <view class="result-list" wx:if="{{!showHistory && !loading}}">
    <view class="result-item" wx:for="{{result}}" wx:key="id"
          bindtap="goToDetail" data-id="{{item.id}}">
      <image class="result-logo" src="{{item.logo}}" mode="aspectFit" binderror="onImgErr" />
      <view class="result-info">
        <view class="result-header">
          <text class="result-name">{{item.name}}</text>
          <view class="result-badges">
            <text class="tag tag-primary" wx:if="{{item.free}}">免费</text>
            <text class="tag tag-secondary" wx:if="{{item.chinese}}">中文</text>
          </view>
        </view>
        <text class="result-desc">{{item.shortDesc}}</text>
        <view class="result-meta">
          <text class="result-cat" style="color:{{item.catColor}}">{{item.category}}</text>
          <text class="result-rating">⭐ {{item.rating}}</text>
        </view>
      </view>
    </view>

    <!-- 无结果 -->
    <view class="no-result" wx:if="{{result.length === 0 && searchValue}}">
      <text class="no-result-icon">🔍</text>
      <text class="no-result-text">未找到「{{searchValue}}」相关工具</text>
      <text class="no-result-hint">试试其他关键词</text>
    </view>
  </view>

</view>
