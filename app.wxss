/**app.wxss**/
.container { min-height: 100vh; background-color: #0f0f1a; color: #e6e6e6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
.card { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); border-radius: 16rpx; padding: 30rpx; margin: 20rpx; box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3); border: 1px solid rgba(100, 255, 218, 0.1); }
.tag { display: inline-block; padding: 6rpx 16rpx; border-radius: 20rpx; font-size: 22rpx; margin-right: 10rpx; margin-bottom: 10rpx; }
.tag-primary { background: rgba(100, 255, 218, 0.15); color: #64ffda; }
.tag-secondary { background: rgba(149, 117, 205, 0.15); color: #c792ea; }
.tag-warning { background: rgba(255, 165, 0, 0.15); color: #ffa500; }
.btn { background: linear-gradient(135deg, #64ffda 0%, #00b4d8 100%); color: #0f0f1a; border: none; border-radius: 50rpx; padding: 20rpx 60rpx; font-weight: 600; font-size: 28rpx; }
.flex { display: flex; flex-wrap: wrap; }
